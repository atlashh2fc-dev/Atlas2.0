{
  "manifest_version": 3,
  "name": "CRM Extractor Pro",
  "version": "3.3.0",
  "description": "Detecta número del discador automáticamente, extrae datos de Atlas/Equifax, historial permanente y respaldo CSV.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "clipboardWrite",
    "clipboardRead",
    "downloads",
    "alarms",
    "debugger",
    "contextMenus",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}