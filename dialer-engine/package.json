{
  "name": "atlas-dialer-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Motor de discado de Atlas 2.0: conecta Asterisk (AMI) con el CRM via RPCs de Supabase. Servicio propio, independiente del deploy de Next.js.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "@types/ws": "^8.18.1",
    "asterisk-manager": "^0.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pino": "^9.4.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20",
    "tsx": "^4.19.1",
    "typescript": "^5"
  }
}
